"pub fn gelu_forward < T : Triton, const BLOCK_SIZE : i32 >\n(x_ptr : T :: Pointer < f32 > , y_ptr : T :: Pointer < f32 > , n_elements :\ni32,) where T :: I32Tensor : types :: Tensor < i32, 1 > , T :: I32Tensor :\nComparison < i32, BoolTensor = T :: BoolTensor > , T :: Pointer < f32 > :\nAddOffsets < i32, 1, T :: I32Tensor, Output = T :: Tensor < T :: Pointer < f32\n> > > ,\n{\n    let pid = T :: program_id(Axis :: X); let block_start = pid * BLOCK_SIZE;\n    let offsets = T :: arange(0, BLOCK_SIZE) + block_start; let in_bounds =\n    offsets.lt(n_elements); let x = T ::\n    load(x_ptr.add_offsets(offsets), Some(in_bounds), None, & [], None, None,\n    None, false); let one = T :: full(& [BLOCK_SIZE], 1.0_f32); let neg2c = T\n    :: full(& [BLOCK_SIZE], - 2.0_f32 * 0.7978845608028654_f32); let coeff = T\n    :: full(& [BLOCK_SIZE], 0.044715_f32); let inner = x + coeff * x * x * x;\n    let y = x / (one + T :: exp(neg2c * inner)); T ::\n    store(y_ptr.add_offsets(offsets), y, Some(in_bounds), & [], None, None);\n}\n\nuse triton::llvm::triton::num::*;\nuse triton::llvm::triton::pointer::LlvmPointer;\ntype LlvmTriton = triton::llvm::triton::LlvmTriton;\n\n#[no_mangle]\npub extern \"C\" fn entry_point(x_ptr: *mut f32, y_ptr: *mut f32, n_elements: i32) {\n    let x_ptr = LlvmPointer(x_ptr as *mut _);\n    let y_ptr = LlvmPointer(y_ptr as *mut _);\n    gelu_forward::<LlvmTriton, 128>(x_ptr, y_ptr, n_elements);\n}"
