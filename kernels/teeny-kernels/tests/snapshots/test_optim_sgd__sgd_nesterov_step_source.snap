"pub fn sgd_nesterov_step < T : Triton, const BLOCK_SIZE : i32 >\n(params_ptr : T :: Pointer < f32 > , grad_ptr : T :: Pointer < f32 > , buf_ptr\n: T :: Pointer < f32 > , n_elements : i32, lr : f32, momentum : f32, dampening\n: f32, weight_decay : f32,) where T :: I32Tensor : types :: Tensor < i32, 1 >\n, T :: I32Tensor : Comparison < i32, BoolTensor = T :: BoolTensor > , T ::\nPointer < f32 > : AddOffsets < i32, 1, T :: I32Tensor, Output = T :: Tensor <\nT :: Pointer < f32 > > > ,\n{\n    let pid = T :: program_id(Axis :: X); let block_start = pid * BLOCK_SIZE;\n    let offsets = T :: arange(0, BLOCK_SIZE) + block_start; let mask =\n    offsets.lt(n_elements); let p = T ::\n    load(params_ptr.add_offsets(offsets), Some(mask), None, & [], None, None,\n    None, false); let g = T ::\n    load(grad_ptr.add_offsets(offsets), Some(mask), None, & [], None, None,\n    None, false); let buf = T ::\n    load(buf_ptr.add_offsets(offsets), Some(mask), None, & [], None, None,\n    None, false); let lr_t = T :: full(& [BLOCK_SIZE], lr); let mu_t = T ::\n    full(& [BLOCK_SIZE], momentum); let damp_t = T ::\n    full(& [BLOCK_SIZE], 1.0_f32 - dampening); let wd_t = T ::\n    full(& [BLOCK_SIZE], weight_decay); let g_eff = g + wd_t * p; let buf_new\n    = mu_t * buf + damp_t * g_eff; let g_nes = g_eff + mu_t * buf_new; let\n    p_new = p - lr_t * g_nes; T ::\n    store(params_ptr.add_offsets(offsets), p_new, Some(mask), & [], None,\n    None); T ::\n    store(buf_ptr.add_offsets(offsets), buf_new, Some(mask), & [], None,\n    None);\n}\n\nuse triton::llvm::triton::num::*;\nuse triton::llvm::triton::pointer::LlvmPointer;\ntype LlvmTriton = triton::llvm::triton::LlvmTriton;\n\n#[no_mangle]\npub extern \"C\" fn entry_point(params_ptr: *mut f32, grad_ptr: *mut f32, buf_ptr: *mut f32, n_elements: i32, lr: f32, momentum: f32, dampening: f32, weight_decay: f32) {\n    let params_ptr = LlvmPointer(params_ptr as *mut _);\n    let grad_ptr = LlvmPointer(grad_ptr as *mut _);\n    let buf_ptr = LlvmPointer(buf_ptr as *mut _);\n    sgd_nesterov_step::<LlvmTriton, 128>(params_ptr, grad_ptr, buf_ptr, n_elements, lr, momentum, dampening, weight_decay);\n}"
