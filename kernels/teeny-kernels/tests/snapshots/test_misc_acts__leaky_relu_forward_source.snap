"pub fn leaky_relu_forward < T : Triton, const BLOCK_SIZE : i32 >\n(x_ptr : T :: Pointer < f32 > , y_ptr : T :: Pointer < f32 > , n_elements :\ni32, negative_slope : f32,) where T :: I32Tensor : types :: Tensor < i32, 1 >\n, T :: I32Tensor : Comparison < i32, BoolTensor = T :: BoolTensor > , T ::\nPointer < f32 > : AddOffsets < i32, 1, T :: I32Tensor, Output = T :: Tensor <\nT :: Pointer < f32 > > > ,\n{\n    let pid = T :: program_id(Axis :: X); let block_start = pid * BLOCK_SIZE;\n    let offsets = T :: arange(0, BLOCK_SIZE) + block_start; let in_bounds =\n    offsets.lt(n_elements); let x = T ::\n    load(x_ptr.add_offsets(offsets), Some(in_bounds), None, & [], None, None,\n    None, false); let slope = T :: full(& [BLOCK_SIZE], negative_slope); let\n    x_pos = T :: gt(x, T :: zeros_like(x)); let y = T ::\n    where_(x_pos, x, slope * x); T ::\n    store(y_ptr.add_offsets(offsets), y, Some(in_bounds), & [], None, None);\n}\n\nuse triton::llvm::triton::num::*;\nuse triton::llvm::triton::pointer::LlvmPointer;\ntype LlvmTriton = triton::llvm::triton::LlvmTriton;\n\n#[no_mangle]\npub extern \"C\" fn entry_point(x_ptr: *mut f32, y_ptr: *mut f32, n_elements: i32, negative_slope: f32) {\n    let x_ptr = LlvmPointer(x_ptr as *mut _);\n    let y_ptr = LlvmPointer(y_ptr as *mut _);\n    leaky_relu_forward::<LlvmTriton, 128>(x_ptr, y_ptr, n_elements, negative_slope);\n}"
