"pub fn muon_update < T : Triton, const BLOCK_SIZE : i32 >\n(params_ptr : T :: Pointer < f32 > , grad_ptr : T :: Pointer < f32 > ,\nn_elements : i32, lr : f32,) where T :: I32Tensor : types :: Tensor < i32, 1 >\n, T :: I32Tensor : Comparison < i32, BoolTensor = T :: BoolTensor > , T ::\nPointer < f32 > : AddOffsets < i32, 1, T :: I32Tensor, Output = T :: Tensor <\nT :: Pointer < f32 > > > ,\n{\n    let pid = T :: program_id(Axis :: X); let offsets = T ::\n    arange(0, BLOCK_SIZE) + pid * BLOCK_SIZE; let mask =\n    offsets.lt(n_elements); let p = T ::\n    load(params_ptr.add_offsets(offsets), Some(mask), None, & [], None, None,\n    None, false); let g = T ::\n    load(grad_ptr.add_offsets(offsets), Some(mask), None, & [], None, None,\n    None, false); let lr_t = T :: full :: < f32 > (& [BLOCK_SIZE], lr); T ::\n    store(params_ptr.add_offsets(offsets), p - lr_t * g, Some(mask), & [],\n    None, None);\n}\n\nuse triton::llvm::triton::num::*;\nuse triton::llvm::triton::pointer::LlvmPointer;\ntype LlvmTriton = triton::llvm::triton::LlvmTriton;\n\n#[no_mangle]\npub extern \"C\" fn entry_point(params_ptr: *mut f32, grad_ptr: *mut f32, n_elements: i32, lr: f32) {\n    let params_ptr = LlvmPointer(params_ptr as *mut _);\n    let grad_ptr = LlvmPointer(grad_ptr as *mut _);\n    muon_update::<LlvmTriton, 128>(params_ptr, grad_ptr, n_elements, lr);\n}"
