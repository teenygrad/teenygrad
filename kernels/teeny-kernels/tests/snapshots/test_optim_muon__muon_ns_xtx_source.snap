"pub fn muon_ns_xtx < T : Triton, const TRANSPOSE : bool, const BLOCK_R : i32,\nconst BLOCK_K : i32, const GROUP_R : i32, >\n(x_ptr : T :: Pointer < f32 > , t_ptr : T :: Pointer < f32 > , M : i32, N :\ni32, stride_xm : i32,)\n{\n    let R = if TRANSPOSE { N } else { M }; let K = if TRANSPOSE { M } else\n    { N }; let a_stride_row = if TRANSPOSE { 1 } else { stride_xm }; let\n    a_stride_col = if TRANSPOSE { stride_xm } else { 1 }; let pid = T ::\n    program_id(Axis :: X); let num_pid_r = T :: cdiv(R, BLOCK_R); let\n    num_pid_in_group = GROUP_R * num_pid_r; let group_id = pid /\n    num_pid_in_group; let first_pid_r = group_id * GROUP_R; let remaining =\n    num_pid_r - first_pid_r; let group_size = if remaining < GROUP_R\n    { remaining } else { GROUP_R }; let pid_in_group = pid % num_pid_in_group;\n    let pid_rm = first_pid_r + (pid_in_group % group_size); let pid_rn =\n    pid_in_group / group_size; let a_desc = T ::\n    make_tensor_descriptor(x_ptr, & [R, K], & [a_stride_row, a_stride_col], &\n    [BLOCK_R, BLOCK_K], Some(PaddingOption :: Zero)); let b_desc = T ::\n    make_tensor_descriptor(x_ptr, & [R, K], & [a_stride_row, a_stride_col], &\n    [BLOCK_R, BLOCK_K], Some(PaddingOption :: Zero)); let mut acc = T :: zeros\n    :: < f32 > (& [BLOCK_R, BLOCK_R]); let k_tiles = T :: cdiv(K, BLOCK_K);\n    for k in 0 .. k_tiles\n    {\n        let a = T ::\n        load_tensor_descriptor(a_desc, & [pid_rm * BLOCK_R, k * BLOCK_K]); let\n        b = T ::\n        load_tensor_descriptor(b_desc, & [pid_rn * BLOCK_R, k * BLOCK_K]); let\n        b_t = T :: trans(b, & [1, 0]); acc = T :: dot :: < f32, f32 >\n        (a, b_t, Some(acc), None, None);\n    } let t_desc = T ::\n    make_tensor_descriptor(t_ptr, & [R, R], & [R, 1], & [BLOCK_R, BLOCK_R],\n    Some(PaddingOption :: Zero)); T ::\n    store_tensor_descriptor(t_desc, & [pid_rm * BLOCK_R, pid_rn * BLOCK_R],\n    acc);\n}\n\nuse triton::llvm::triton::num::*;\nuse triton::llvm::triton::pointer::LlvmPointer;\ntype LlvmTriton = triton::llvm::triton::LlvmTriton;\n\n#[no_mangle]\npub extern \"C\" fn entry_point(x_ptr: *mut f32, t_ptr: *mut f32, M: i32, N: i32, stride_xm: i32) {\n    let x_ptr = LlvmPointer(x_ptr as *mut _);\n    let t_ptr = LlvmPointer(t_ptr as *mut _);\n    muon_ns_xtx::<LlvmTriton, false, 32, 32, 8>(x_ptr, t_ptr, M, N, stride_xm);\n}"
